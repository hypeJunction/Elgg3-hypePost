{
    "name": "hypejunction/hypepost",
    "type": "elgg-plugin",
    "description": "Utility plugin for quick prototyping of content posts",
    "homepage": "https://github.com/hypeJunction/Elgg3-hypePost",
    "keywords": [
        "elgg",
        "plugin",
        "forms"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "extra": {
        "installer-name": "hypepost"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "composer/installers": "^2.0",
        "elgg/elgg": "~7.0.0",
        "bower-asset/parsleyjs": "~2.8"
    },
    "autoload": {
        "psr-4": {
            "hypeJunction\\": "classes/hypeJunction/"
        }
    }
}
